# Begin formatted tmux session
function tmux-up() {
  session_name=$1
  if tmux has-session -t $session_name 2>/dev/null; then
    if [[ -n $TMUX ]]; then
      tmux switch-client -t $session_name
    else
      tmux attach -t $session_name
    fi
  else
    if [ -f ~/.tmuxp/$session_name.yaml ]; then
      TMUX="" tmuxp load -d $session_name && tmux switch-client -t $session_name
    else
      TMUX="" tmuxp load -d -s $session_name default && tmux switch-client -t $session_name
    fi
  fi
}
